# TripCanvas environment example
# Copy to `.env` for backend runs from the repo root.
# When running the Next.js app from `frontend/`, either export the NEXT_PUBLIC_*
# vars in your shell or copy those lines into `frontend/.env.local`.

# ---------------------------------------------------------------------------
# Backend: required for live extraction/planning
# ---------------------------------------------------------------------------

OPENAI_API_KEY=
APIFY_TOKEN=

# ---------------------------------------------------------------------------
# Backend: demo/cache controls
# ---------------------------------------------------------------------------

# Use committed cache files instead of live extraction/planning when supported.
USE_CACHE=false

# Optional demo Reel inputs for spike scripts. Prefer DEMO_REEL_URLS for 3-4 URLs.
DEMO_REEL_URLS=
DEMO_REEL_URL=

# Optional Booking.com affiliate id for hotel deep links.
BOOKING_AID=

# Deprecated optional Duffel fallback. If set, code requires a Duffel test token.
DUFFEL_TEST_TOKEN=

# ---------------------------------------------------------------------------
# Backend: explicit AP2 + x402 hotel-payment endpoints
# POST /ap2/hotel-booking-mandate and POST /hotel-booking
# ---------------------------------------------------------------------------

# Local/offline default. Set to `demo_signed` to require signed AP2 demo mandates.
AP2_MODE=disabled
AP2_DEMO_SIGNING_SECRET=
AP2_DEMO_ISSUER=tripcanvas-demo-trusted-surface
AP2_DEMO_AUDIENCE=tripcanvas-hotel-booking-agent
AP2_MANDATE_TTL_SECONDS=180

# Local/offline default. Set to `real` only for explicit testnet settlement runs.
X402_MODE=simulation
X402_NETWORK=eip155:84532
X402_FACILITATOR_URL=https://x402.org/facilitator
X402_HOTEL_BOOKING_PRICE_USD=0.01

# Keep unset or `mock`; any other value is rejected by the backend.
HOTEL_BOOKING_MODE=mock

# Required only when X402_MODE=real. Never commit real private keys.
ORCHESTRATOR_PRIVATE_KEY=
ORCHESTRATOR_WALLET_ADDRESS=
HOTEL_AGENT_PAY_TO=

# Required only when X402_MODE=hsp_testnet. HSP_SDK_PATH points to a local
# clone of https://github.com/project-hsp/hsp after running `npm install` there.
HSP_COORDINATOR_URL=https://hsp-hackathon.hashkeymerchant.com
HSP_API_KEY=
HSP_PRIVATE_KEY=
HSP_CHAIN=hashkey-testnet
HSP_FACILITATOR_URL=https://hsp-hackathon.hashkeymerchant.com/facilitator
HSP_ISSUER_URL=https://hsp-hackathon.hashkeymerchant.com/issuer
HSP_RPC_URL=https://testnet.hsk.xyz
HSP_SDK_PATH=
HSP_PAYER_ADDRESS=
HSP_PAYEE_ADDRESS=
HSP_USDC_ADDRESS=0x8FE3cB719Ee4410E236Cd6b72ab1fCDC06eF53c6
HSP_ADAPTER_ADDRESS=0x467AaF355DF243379B961Ce00abBae20c1e25012
HSP_PAYMENT_AMOUNT_USDC=0.01
HSP_AWAIT_SETTLED_TIMEOUT_MS=120000

# ---------------------------------------------------------------------------
# Backend: itinerary booking overlay payment seam
# ---------------------------------------------------------------------------

USE_MOCK_PAYMENT=true
PAYMENT_NETWORK=mock

# ---------------------------------------------------------------------------
# Frontend: public browser-visible variables
# ---------------------------------------------------------------------------

NEXT_PUBLIC_MAPBOX_TOKEN=
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Optional legacy/custom trip-generation endpoint used by frontend/lib/trip/api.ts.
NEXT_PUBLIC_TRIP_ENDPOINT=

# Comma-separated production frontend origins allowed by the FastAPI backend.
# Example: https://tripcanvas.vercel.app,https://tripcanvas-git-main-team.vercel.app
CORS_ALLOW_ORIGINS=
